<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel ="stylesheet" href="style.css"/>
</head>
<body>
    <h2>All Chats</h2>
    <form method="GET" action="/chats/new">
        <button>New Chat</button>
    </form>
    <br>

    <% for(let chat of chats){ %>
        <div class="chat">
            <p>From : <b><i><%= chat.from%></i></b></p>
            <div class="msg">
                <p><%= chat.msg%></p>
                <form method="GET" action="/chats/<%= chat._id %>/edit">
                    <button>Edit</button>
                </form>
                <form method="POST" action="/chats/<%= chat._id %>?_method=DELETE" onsubmit="return confirmDelete()">
                    <button type="submit" class="delete-btn">Delete</button>
                </form>
                <form action="/chats/<%= chat._id %>" method="GET">
                    <button>Show</button>
                </form>
            </div>
            <p>Received by <b><i><%=chat.to%></i></b></p>
            <hr>
            <h3>Created at: <%= chat.createdAt ? chat.createdAt.toString().split(" ")[4] : "N/A" %></h3>
            <p><%= chat.createdAt ? chat.createdAt.toDateString() : "Date Unknown" %></p>   
            <h3>Updated at: <%= chat.updatedAt ? chat.updatedAt.toLocaleTimeString() : "N/A" %></h3>
        </div>
        <br><br>
    <%}%>
    
    <script>
        function confirmDelete() {
            // window.confirm returns true if user clicks 'OK' and false if 'Cancel'
            let result = confirm("Are you sure you want to delete this chat?");
            if (result) {
                return true; // The form will be submitted
            } else {
                return false; // The form submission is cancelled
            }
        }
    </script>
</body>
</html>
